# -----------------------------
# Local Development Environment
# -----------------------------

# Database
DATABASE_URL=postgresql://<username>:<password>@<host>:5432/<database>?sslmode=require

# Redis / Celery (local)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# App runtime
SECRET_KEY=<set-a-strong-secret>
JWT_SECRET=<optional-jwt-secret>
ENVIRONMENT=development
LOG_LEVEL=info
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Keyword extraction
KEYWORD_EXTRACTOR=auto
KEYWORD_TOP_N=10
KEYWORD_NGRAM_MIN=1
KEYWORD_NGRAM_MAX=2
KEYBERT_MODEL_NAME=all-MiniLM-L6-v2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=
VITE_OAUTH_PORTAL_URL=https://manus.im
VITE_APP_ID=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# OAuth / external APIs
OAUTH_SERVER_URL=https://api.manus.im
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Docker Compose internal network overrides
POSTGRES_USER=docflow
POSTGRES_PASSWORD=docflow_secret
POSTGRES_DB=docflow_db
DOCKER_DATABASE_URL=postgresql://docflow:docflow_secret@postgres:5432/docflow_db
DOCKER_REDIS_URL=redis://redis:6379/0
DOCKER_CELERY_BROKER_URL=redis://redis:6379/1
DOCKER_CELERY_RESULT_BACKEND=redis://redis:6379/2
